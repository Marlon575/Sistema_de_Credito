# =============================================================
# .env.example — Modelo de configuração do backend CréditoMZ
#
# Este ficheiro é seguro para subir ao GitHub: não tem segredos.
# Para usar:
#   1. Copia este ficheiro e renomeia a cópia para ".env"
#   2. Substitui os valores de exemplo pelos valores reais
#      (nunca commits o .env com valores reais!)
# =============================================================

# ---- Base de dados ----
DATABASE_URL="postgresql://USUARIO:PASSWORD@localhost:5433/creditomz_db?schema=public"

# ---- Servidor ----
PORT=3000
NODE_ENV=development

# ---- JWT (tokens de autenticação) ----
# Gera valores fortes e aleatórios com o comando abaixo (no terminal):
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET="gera_uma_chave_aleatoria_forte_aqui"
JWT_REFRESH_SECRET="gera_outra_chave_aleatoria_forte_aqui"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ---- CORS ----
FRONTEND_URL="http://localhost:5500"