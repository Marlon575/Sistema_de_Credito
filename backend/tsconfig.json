{
  "compilerOptions": {
    // ---- Onde vai o resultado traduzido (só para build de produção) ----
    "outDir": "./dist",

    // ---- Que versão de JavaScript gerar ----
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",

    // ---- Regras de rigor (evitam erros comuns) ----
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    // ---- Outras opções úteis ----
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true
  },

  // Quais pastas o TypeScript deve incluir
  "include": ["src/**/*.ts", "prisma/**/*.ts"],

  // Pastas que o TypeScript deve ignorar
  "exclude": ["node_modules", "dist"]
}